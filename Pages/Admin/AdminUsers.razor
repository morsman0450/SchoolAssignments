@page "/admin/users"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.EntityFrameworkCore
@using SchoolAssignments.Data
@using SchoolAssignments.Models
@inject AppDbContext Db
@inject NavigationManager Navigation
@inject IJSRuntime JsRuntime

<div class="container mt-4 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">
                <i class="bi bi-shield-lock text-primary me-2"></i>Správa uživatelů
            </h3>
            <p class="text-muted small mb-0">Správa přístupů, rolí a uživatelských účtů v systému.</p>
        </div>
        <button class="btn btn-success shadow-sm rounded-pill px-4 fw-bold d-flex align-items-center gap-2"
                @onclick='() => Navigation.NavigateTo("/create-user")'>
            <i class="bi bi-person-plus-fill fs-5"></i> Nový uživatel
        </button>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <div class="row g-2 align-items-center">
                <div class="col-md-5">
                    <div class="input-group border rounded-3 overflow-hidden shadow-none">
                        <span class="input-group-text bg-white border-0 text-muted"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control border-0 shadow-none ps-0"
                               placeholder="Hledat podle jména nebo emailu..."
                               @bind="searchTerm" @bind:event="oninput" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select border rounded-3 shadow-none bg-light" @bind="selectedRole">
                        <option value="">Všechny role</option>
                        @foreach (var role in Enum.GetValues<UserRole>())
                        {
                            <option value="@role">@role</option>
                        }
                    </select>
                </div>
                <div class="col-md-4 text-md-end">
                    <span class="text-muted small">Nalezeno: <strong>@FilteredUsers.Count()</strong> uživatelů</span>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light border-bottom">
                    <tr class="text-secondary small text-uppercase fw-bold">
                        <th class="ps-4 py-3">Uživatel</th>
                        <th>Email</th>
                        <th class="text-center">Role</th>
                        <th class="text-end pe-4">Akce</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!FilteredUsers.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="bi bi-person-x display-4 d-block mb-2 opacity-25"></i>
                                Žádní uživatelé neodpovídají vyhledávání.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in FilteredUsers)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-3 bg-primary-soft text-primary fw-bold">
                                            @user.FirstName[0]@user.LastName[0]
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@user.FirstName @user.LastName</div>
                                            <div class="extra-small text-muted">ID: #@user.Id</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-muted small">@user.Email</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge rounded-pill fw-medium px-3 py-2 bg-@GetRoleColor(user.Role)-soft text-@GetRoleColor(user.Role)">
                                        @user.Role
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm rounded-3 overflow-hidden border">
                                        <button class="btn btn-white btn-sm border-0 px-3 text-primary"
                                                title="Upravit" @onclick="() => EditUser(user.Id)">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button class="btn btn-white btn-sm border-0 px-3 text-danger"
                                                title="Smazat" @onclick="() => DeleteUser(user.Id)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* SOFT BARVY PRO ROLE (Doplnit do CSS nebo inline) */
    .bg-primary-soft {
        background-color: rgba(13, 110, 253, 0.1);
    }

    .text-primary {
        color: #0d6efd !important;
    }

    .bg-success-soft {
        background-color: rgba(25, 135, 84, 0.1);
    }

    .text-success {
        color: #198754 !important;
    }

    .bg-warning-soft {
        background-color: rgba(255, 193, 7, 0.15);
    }

    .text-warning {
        color: #856404 !important;
    }

    .bg-danger-soft {
        background-color: rgba(220, 53, 69, 0.1);
    }

    .text-danger {
        color: #dc3545 !important;
    }

    /* Avatar s iniciály */
    .avatar-circle {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
    }

    .extra-small {
        font-size: 0.75rem;
    }

    /* Tlačítka v tabulce */
    .btn-white {
        background: #fff;
    }

        .btn-white:hover {
            background: #f8f9fa;
        }

    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.02);
    }
</style>

@code {
    private List<User> users = new();
    private string searchTerm = "";
    private string selectedRole = "";

    private IEnumerable<User> FilteredUsers => users
        .Where(u =>
            (string.IsNullOrWhiteSpace(searchTerm)
                || $"{u.FirstName} {u.LastName} {u.Email}"
                    .Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
            && (string.IsNullOrWhiteSpace(selectedRole)
                || u.Role.ToString() == selectedRole))
        .OrderBy(u => u.LastName)
        .ThenBy(u => u.FirstName);

    protected override async Task OnInitializedAsync()
    {
        users = await Db.Users.AsNoTracking().ToListAsync();
    }

    private string GetRoleColor(UserRole role) => role switch
    {
        UserRole.Admin => "danger",
        UserRole.Teacher => "primary",
        UserRole.Student => "success",
        _ => "secondary"
    };

    private void EditUser(int id)
    {
        var user = users.FirstOrDefault(u => u.Id == id);
        if (user == null) return;

        if (user.Role == UserRole.Teacher)
            Navigation.NavigateTo($"/admin/edit-teacher/{id}");
        else if (user.Role == UserRole.Student)
            Navigation.NavigateTo($"/admin/edit-student/{id}");
        else
            Navigation.NavigateTo($"/admin/edit-user/{id}");
    }

    private async Task DeleteUser(int id)
    {
        var confirm = await JsRuntime.InvokeAsync<bool>("confirm",
            "Opravdu chcete tohoto uživatele smazat?");
        if (!confirm) return;

        var user = await Db.Users.FindAsync(id);
        if (user is not null)
        {
            Db.Users.Remove(user);
            await Db.SaveChangesAsync();
            users.Remove(user);
        }
    }
}

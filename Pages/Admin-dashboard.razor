@page "/admin-dashboard"

@attribute [Authorize(Roles = "Admin")]

<div class="container py-4">
    <h2 class="mb-4">🤵 Admin Dashboard</h2>

    <!-- Statistiky karet -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-bg-primary mb-3">
                <div class="card-body">
                    <h5 class="card-title">Uživatelé</h5>
                    <p class="card-text display-6">320</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-success mb-3">
                <div class="card-body">
                    <h5 class="card-title">Aktivní úkoly</h5>
                    <p class="card-text display-6">124</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-warning mb-3">
                <div class="card-body">
                    <h5 class="card-title">Přihlášení uživatelé</h5>
                    <p class="card-text display-6">38</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-danger mb-3">
                <div class="card-body">
                    <h5 class="card-title">Chyby / Logy</h5>
                    <p class="card-text display-6">5</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Graf aktivity a seznam -->
    <div class="row">
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header">Aktivita za poslední týden</div>
                <div class="card-body">
                    <canvas id="activityChart" height="200"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header">Poslední přihlášení</div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">student01 – dnes v 8:43</li>
                    <li class="list-group-item">teacher05 – dnes v 8:12</li>
                    <li class="list-group-item">admin – včera v 22:10</li>
                    <li class="list-group-item">student12 – včera v 20:55</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Sekce správy -->
    <div class="row">
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header">Správa uživatelů</div>
                <div class="card-body">
                    <a href="/admin/users" class="btn btn-outline-primary w-100">Zobrazit uživatele</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header">Správa úkolů</div>
                <div class="card-body">
                    <a href="/admin/assignments" class="btn btn-outline-success w-100">Zobrazit úkoly</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header">Nastavení systému</div>
                <div class="card-body">
                    <a href="/admin/settings" class="btn btn-outline-secondary w-100">Přejít na nastavení</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Vložení Chart.js pro graf -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const ctx = document.getElementById('activityChart');
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: ['Po', 'Út', 'St', 'Čt', 'Pá', 'So', 'Ne'],
            datasets: [{
                label: 'Počet akcí',
                data: [12, 19, 3, 5, 2, 3, 7],
                borderWidth: 2,
                borderColor: '#0d6efd',
                fill: false
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    display: false
                }
            },
            scales: {
                y: {
                    beginAtZero: true
                }
            }
        }
    });
</script>





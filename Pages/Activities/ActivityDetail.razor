@page "/activity-detail/{ActivityId:int}"
@using SchoolAssignments.Models
@using SchoolAssignments.Services
@inject IActivityService ActivityService
@inject NavigationManager Navigation

<div class="container mt-4 pb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-2">
            <li class="breadcrumb-item"><a href="/activities" class="text-decoration-none">Moje aktivity</a></li>
            <li class="breadcrumb-item active">Detail aktivity</li>
        </ol>
    </nav>

    @if (activity == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="text-muted mt-2">Načítám detail aktivity...</p>
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0 text-dark">@activity.Title</h2>
            <div>
                <button class="btn btn-outline-secondary me-2" @onclick="GoBack">
                    <i class="bi bi-arrow-left"></i> Zpět
                </button>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white py-3">
                        <h5 class="card-title mb-0 fw-bold text-primary">
                            <i class="bi bi-card-text me-2"></i>Popis a zadání
                        </h5>
                    </div>
                    <div class="card-body p-4">
                        <p class="lead text-dark" style="white-space: pre-wrap;">@activity.Description</p>
                    </div>
                </div>

                @* --- SPECIFICKÝ OBSAH PODLE TYPU --- *@
                @if (activity.Type == ActivityType.Test && activity.Questions != null)
                {
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0 fw-bold text-success">
                                <i class="bi bi-list-check me-2"></i>Seznam otázek
                            </h5>
                            <span class="badge bg-success-soft text-success rounded-pill">@activity.Questions.Count otázek</span>
                        </div>
                        <div class="card-body p-0">
                            <div class="list-group list-group-flush">
                                @foreach (var (question, index) in activity.Questions.Select((q, i) => (q, i)))
                                {
                                    <div class="list-group-item p-4">
                                        <div class="d-flex justify-content-between mb-2">
                                            <h6 class="fw-bold mb-0">@(index + 1). @question.Text</h6>
                                            <span class="badge bg-light text-dark border small">@question.Type</span>
                                        </div>

                                        @if (question.Type == QuestionType.OpenText)
                                        {
                                            <div class="mt-3 p-3 bg-light rounded border-start border-4 border-success">
                                                <small class="text-muted d-block small text-uppercase fw-bold">Správná odpověď:</small>
                                                <span class="text-success fw-bold">@question.CorrectAnswerText</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="row mt-3 g-2">
                                                @foreach (var option in question.Options)
                                                {
                                                    <div class="col-md-6">
                                                        <div class="p-2 rounded border @(option.IsCorrect ? "bg-success-soft border-success" : "bg-white")">
                                                            @if (option.IsCorrect)
                                                            {
                                                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                                            }
                                                            else
                                                            {
                                                                <i class="bi bi-circle me-2 text-muted"></i>
                                                            }
                                                            <span class="@(option.IsCorrect ? "fw-bold text-success" : "")">@option.Text</span>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-light py-3 text-center">
                        <h6 class="mb-0 fw-bold text-uppercase small text-muted">Parametry aktivity</h6>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span class="text-muted"><i class="bi bi-people me-2"></i>Třída</span>
                                <span class="fw-bold">@(activity.ClassTeacherSubject?.Class?.Name ?? "Neuvedeno")</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span class="text-muted"><i class="bi bi-book me-2"></i>Předmět</span>
                                <span class="fw-bold">@(activity.ClassTeacherSubject?.Subject?.Name ?? "Neuvedeno")</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span class="text-muted"><i class="bi bi-tag me-2"></i>Typ</span>
                                <span class="badge bg-primary-soft text-primary">@activity.Type</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span class="text-muted"><i class="bi bi-award me-2"></i>Max. body</span>
                                <span class="fw-bold text-primary fs-5">@activity.MaxPoints b.</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span class="text-muted"><i class="bi bi-calendar-event me-2"></i>Termín</span>
                                <span class="fw-bold @(activity.DueDate.HasValue ? "" : "text-muted italic")">
                                    @(activity.DueDate?.ToString("dd.MM.yyyy HH:mm") ?? "Nenastaven")
                                </span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span class="text-muted"><i class="bi bi-robot me-2"></i>Auto-hodnocení</span>
                                <span>
                                    @if (activity.IsAutoGraded)
                                    {
                                        <span class="text-success fw-bold"><i class="bi bi-check-lg"></i> Ano</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fw-bold"><i class="bi bi-x-lg"></i> Ne</span>
                                    }
                                </span>
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="card bg-primary text-white border-0 shadow-sm">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-send-check mb-2 fs-1"></i>
                        <h5>Přejít k hodnocení</h5>
                        <p class="small opacity-75">Zobrazte si práce studentů a udělte body.</p>
                        <button class="btn btn-light w-100 fw-bold" @onclick="() => NavigateToSubmissions(activity.Id)">
                            Zobrazit odevzdání
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .bg-primary-soft {
        background-color: rgba(13, 110, 253, 0.1);
    }

    .bg-success-soft {
        background-color: rgba(25, 135, 84, 0.1);
    }

    .italic {
        font-style: italic;
    }

    /* Vizuální oddělení otázek v seznamu */
    .list-group-item {
        border-bottom: 1px solid #f0f0f0;
    }

        .list-group-item:last-child {
            border-bottom: none;
        }
</style>

@code {
    [Parameter]
    public int ActivityId { get; set; }

    private Activity? activity;

    protected override async Task OnInitializedAsync()
    {
        activity = await ActivityService.GetActivityWithDetailsAsync(ActivityId);
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/");
    }
    private void NavigateToSubmissions(int activityId)
    {
        Navigation.NavigateTo($"/activity-submissions/{activityId}");

    }
}

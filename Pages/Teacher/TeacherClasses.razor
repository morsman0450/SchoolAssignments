@page "/teacher-classes"
@using SchoolAssignments.Models
@using SchoolAssignments.Services
@using System.Security.Claims
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@inject IClassService ClassService

<div class="container mt-4 pb-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h3 class="fw-bold mb-0 text-dark">
                <i class="bi bi-mortarboard text-primary me-2"></i>Moje třídy
            </h3>
            <p class="text-muted small mb-0">Správa studentů a přehled aktivit v jednotlivých třídách</p>
        </div>
        <span class="badge bg-primary-soft text-primary px-3 py-2 rounded-pill fw-bold">
            @(classes?.Count ?? 0) aktivních tříd
        </span>
    </div>

    @if (classes == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Načítání...</span>
            </div>
            <p class="text-muted">Připravuji seznam vašich tříd...</p>
        </div>
    }
    else if (!classes.Any())
    {
        <div class="card border-0 shadow-sm text-center py-5">
            <div class="card-body">
                <i class="bi bi-people text-light mb-3" style="font-size: 4rem;"></i>
                <h4 class="text-dark fw-bold">Zatím nemáte žádné třídy</h4>
                <p class="text-muted mx-auto" style="max-width: 400px;">
                    Aktuálně nejste přiřazen k žádné třídě. Kontaktujte administrátora pro přidělení výuky.
                </p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var classItem in classes)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 class-card transition-all">
                        <div class="card-header bg-white border-0 pt-4 px-4">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h5 class="fw-bold text-dark mb-0">@classItem.Name</h5>
                                    <span class="badge bg-light text-primary border mt-1">
                                        <i class="bi bi-book me-1"></i> @classItem.Subject
                                    </span>
                                </div>
                                <div class="bg-primary-soft text-primary rounded p-2">
                                    <i class="bi bi-people-fill fs-5"></i>
                                </div>
                            </div>
                        </div>

                        <div class="card-body px-4 py-3">
                            <div class="d-flex flex-column gap-3">
                                <div class="d-flex align-items-center">
                                    <div class="stats-icon bg-light rounded-circle me-3">
                                        <i class="bi bi-person-badge text-secondary"></i>
                                    </div>
                                    <div>
                                        <div class="small text-muted">Studenti</div>
                                        <div class="fw-bold text-dark">@classItem.Students?.Count studentů</div>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center">
                                    <div class="stats-icon bg-light rounded-circle me-3">
                                        <i class="bi bi-clipboard-check text-secondary"></i>
                                    </div>
                                    <div>
                                        <div class="small text-muted">Aktivní úkoly</div>
                                        <div class="fw-bold text-dark">
                                            @(classItem.ClassTeacherSubjects?.SelectMany(cts => cts.Activities).Count() ?? 0) aktivit
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0 px-4 pb-4 pt-0">
                            <hr class="mt-0 mb-3 opacity-10">
                            <button class="btn btn-outline-primary w-100 d-flex align-items-center justify-content-center gap-2 py-2 fw-bold"
                                    @onclick="@(() => ClassDetail(classItem.Id))">
                                <i class="bi bi-gear-fill"></i> Spravovat třídu
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    /* Jemné barvy pro Bootstrap prvky */
    .bg-primary-soft {
        background-color: rgba(13, 110, 253, 0.1);
    }

    /* Efekt při najetí na kartu */
    .class-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .class-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.1) !important;
        }

    /* Ikony statistik */
    .stats-icon {
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }

    /* Plynulé přechody */
    .transition-all {
        transition: all 0.3s ease;
    }
</style>



@code {
    private List<Class>? classes;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        var user = state.User;

        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (int.TryParse(userId, out var teacherId))
        {
            classes = await ClassService.GetTeacherClassesAsync(teacherId);
        }
        else
        {
            classes = new List<Class>();
        }
    }

    private void ClassDetail(int classId)
    {
        Navigation.NavigateTo($"/class-detail/{classId}");
    }
}
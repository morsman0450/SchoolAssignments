@page "/admin/subjects"
@using SchoolAssignments.Models
@using SchoolAssignments.Services
@inject ISubjectService SubjectService
@inject IJSRuntime JS

<h3>Správa předmětů</h3>

<div class="mb-3">
    <label class="form-label">Nový předmět</label>
    <InputText @bind-Value="newSubjectName" class="form-control" />
</div>
<button class="btn btn-primary mb-3" @onclick="CreateSubject">Vytvořit předmět</button>

@if (subjects is not null)
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>ID</th>
                <th>Název</th>
                <th>Akce</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in subjects)
            {
                <tr>
                    <td>@s.Id</td>
                    <td>@s.Name</td>
                    <td>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteSubject(s.Id)">Smazat</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Subject> subjects = new();
    private string newSubjectName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        subjects = await SubjectService.GetAllSubjectsAsync();
    }

    private async Task CreateSubject()
    {
        if (string.IsNullOrWhiteSpace(newSubjectName))
            return;

        var s = await SubjectService.CreateSubjectAsync(new Subject { Name = newSubjectName });
        subjects.Add(s);
        newSubjectName = string.Empty;
    }

    private async Task DeleteSubject(int id)
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", "Opravdu chcete smazat tento předmět?");
        if (!confirm) return;

        await SubjectService.DeleteSubjectAsync(id);
        subjects = subjects.Where(s => s.Id != id).ToList();
    }
}

@page "/teacher-dashboard"
@using System.Security.Claims
@using SchoolAssignments.Models
@using SchoolAssignments.Services
@inject IClassService ClassService
@inject AuthenticationStateProvider AuthStateProvider

<h3>Moje třídy</h3>

@if (classes == null)
{
    <p>Načítám...</p>
}
else if (!classes.Any())
{
    <p>Žádné třídy.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Název</th>
                <th>Předmět</th>
                <th>Studentů</th>
                <th>Aktivit</th>
                <th>Akce</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in classes)
            {
                <tr>
                    <td>@c.Name</td>
                    <td>@c.Subject</td>
                    <td>@c.Students.Count</td>
                    <td>@c.Activities.Count</td>
                    <td>
                        <NavLink class="btn btn-sm btn-primary" href="@($"/class-detail/{c.Id}")">Detail</NavLink>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Class>? classes;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated ?? false)
        {
            var teacherId = int.Parse(user.FindFirst(ClaimTypes.NameIdentifier)!.Value);
            classes = await ClassService.GetTeacherClassesAsync(teacherId);
        }
    }
}

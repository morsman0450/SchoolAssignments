@page "/class-detail/{ClassId:int}"
@using SchoolAssignments.Models
@using SchoolAssignments.Services
@inject IClassService ClassService
@inject IActivityService ActivityService
@inject NavigationManager Navigation

<h3>Detail třídy: @(classModel != null ? classModel.Name : "Načítám…")</h3>

@if (isLoading)
{
    <p><em>Načítám data třídy...</em></p>
}
else if (classModel == null)
{
    <p class="text-danger"><strong>Třída nebyla nalezena.</strong></p>
}
else
{
    <div class="row mb-4">
        <!-- Informace o třídě -->
        <div class="col-md-4">
            <div class="card p-3">
                <h5>Informace o třídě</h5>
                <p><strong>Název:</strong> @classModel.Name</p>
                <p><strong>Počet studentů:</strong> @(classModel.Students?.Count ?? 0)</p>
                <p><strong>Počet aktivit:</strong> @(classModel.ClassTeacherSubjects?.Sum(cts => cts.Activities?.Count ?? 0))</p>
            </div>
        </div>

        <!-- Učitelé a předměty -->
        <div class="col-md-4">
            <div class="card p-3">
                <h5>Učitelé a předměty</h5>
                @if (classModel.ClassTeacherSubjects != null && classModel.ClassTeacherSubjects.Any())
                {
                    <table class="table table-sm">
                        <thead>
                            <tr><th>Učitel</th><th>Předmět</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var cts in classModel.ClassTeacherSubjects)
                            {
                                <tr>
                                    <td>@cts.Teacher.FirstName @cts.Teacher.LastName</td>
                                    <td>@cts.Subject.Name</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p>Žádní učitelé přiřazeni.</p>
                }
              
            </div>
        </div>

        <!-- Studenti -->
        <div class="col-md-4">
            <div class="card p-3">
                <h5>Studenti</h5>
                @if (classModel.Students != null && classModel.Students.Any())
                {
                    <table class="table table-sm">
                        <thead>
                            <tr><th>Jméno</th><th>Email</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var cs in classModel.Students)
                            {
                                <tr>
                                    <td>@cs.Student.FirstName @cs.Student.LastName</td>
                                    <td>@cs.Student.Email</td>
                                   
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p>Žádní studenti přiřazeni.</p>
                }
            </div>
        </div>
    </div>

    <!-- Aktivity -->
    <h5>Aktivity</h5>
    @if (classModel.ClassTeacherSubjects != null && classModel.ClassTeacherSubjects.Any(cts => cts.Activities != null && cts.Activities.Any()))
    {
        <table class="table table-striped">
            <thead>
                <tr><th>Název</th><th>Typ</th><th>Max bodů</th><th>Termín</th><th>Akce</th></tr>
            </thead>
            <tbody>
                @foreach (var cts in classModel.ClassTeacherSubjects)
                {
                    @foreach (var activity in cts.Activities.OrderByDescending(a => a.CreatedAt))
                    {
                        <tr class="@(!activity.IsActive ? "table-secondary" : "")">
                            <td>@activity.Title</td>
                            <td>@activity.Type</td>
                            <td>@activity.MaxPoints</td>
                            <td>@activity.DueDate?.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <button class="btn btn-sm btn-primary" @onclick="() => NavigateToActivity(activity.Id)">Detail</button>
                                <button class="btn btn-sm btn-warning" @onclick="() => EditActivity(activity.Id)">Upravit</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteActivity(activity.Id)">Smazat</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    }
    else
    {
        <p>Žádné aktivity.</p>
    }
}

@code {
    [Parameter]
    public int ClassId { get; set; }

    private Class? classModel;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            classModel = await ClassService.GetClassByIdAsync(ClassId);
        }
        catch
        {
            classModel = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NavigateToActivity(int activityId)
    {
        Navigation.NavigateTo($"/activity-detail/{activityId}");
    }

    private void EditActivity(int activityId)
    {
        Navigation.NavigateTo($"/edit-activity/{activityId}");
    }

    private async Task DeleteActivity(int activityId)
    {
        var activity = await ActivityService.GetActivityWithDetailsAsync(activityId);
        if (activity != null)
        {
            activity.IsActive = false;
            await ActivityService.UpdateActivityAsync(activity);
            classModel = await ClassService.GetClassByIdAsync(ClassId); // refresh
        }
    }
}

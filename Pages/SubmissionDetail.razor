@page "/submission-detail/{SubmissionId:int}"
@using SchoolAssignments.Models
@using SchoolAssignments.Services
@inject ISubmissionService SubmissionService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<h3>Detail odevzdání</h3>

@if (isLoading)
{
    <p><em>Načítám...</em></p>
}
else if (loadError)
{
    <p class="text-danger">Nepodařilo se načíst odevzdání.</p>
}
else if (submission != null)
{
    <div class="card p-3 shadow-sm">
        <h5>@submission.Student.FirstName @submission.Student.LastName</h5>
        <p><strong>Aktivita:</strong> @submission.Activity.Title</p>
        <p><strong>Odevzdáno:</strong> @submission.SubmittedAt.ToLocalTime()</p>

        <hr />

        @if (isTeacher)
        {
            <EditForm Model="@submission" OnValidSubmit="SaveFeedbackAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label for="points" class="form-label">Body</label>
                    <InputNumber id="points" class="form-control" @bind-Value="submission.Points" />
                </div>

                <div class="mb-3">
                    <label for="feedback" class="form-label">Feedback</label>
                    <InputTextArea id="feedback" class="form-control" @bind-Value="submission.Feedback" Rows="4" />
                </div>

                <button type="submit" class="btn btn-success">💾 Uložit</button>
                <button type="button" class="btn btn-secondary ms-2" @onclick="BackToActivity">⬅ Zpět</button>
            </EditForm>
        }
        else
        {
            <div class="mb-3">
                <label class="form-label"><strong>Body:</strong></label>
                <p>@(submission.Points.HasValue ? submission.Points.Value.ToString() : "-") / @submission.Activity.MaxPoints</p>
            </div>

            <div class="mb-3">
                <label class="form-label"><strong>Feedback učitele:</strong></label>
                <p>@(string.IsNullOrEmpty(submission.Feedback) ? "-" : submission.Feedback)</p>
            </div>

            <button class="btn btn-secondary" @onclick="BackToActivity">⬅ Zpět</button>
        }

        <hr />

        <h5>Odpovědi studenta</h5>

        @* Kódová aktivita *@
        @if (submission.Activity.Type == ActivityType.Code)
        {
            <p><strong>Kódová odpověď:</strong></p>
            <pre class="bg-dark text-light p-2 rounded"><code>@submission.Code</code></pre>

            @if (!string.IsNullOrEmpty(submission.StdOutput))
            {
                <h6>Výstup programu:</h6>
                <pre>@submission.StdOutput</pre>
            }

            @if (!string.IsNullOrEmpty(submission.Stderr))
            {
                <h6>Chybový výstup:</h6>
                <pre>@submission.Stderr</pre>
            }
        }

        @* File aktivita *@
        @if (submission.Activity.Type == ActivityType.File && submission.Files != null && submission.Files.Any())
        {
            <hr />
            <h5>Odevzdané soubory</h5>
            <ul>
                @foreach (var file in submission.Files)
                {
                    <li>
                        <strong>@file.FileName</strong>
                        <a class="btn btn-sm btn-primary ms-2" href="@file.FilePath" download="@file.FileName">📂 Stáhnout</a>
                    </li>
                }
            </ul>
        }

        @* Test aktivita *@
        @if (submission.Activity.Type == ActivityType.Test && submission.StudentAnswers != null && submission.StudentAnswers.Any())
        {
            @foreach (var question in submission.Activity.Questions)
            {
                <div class="mb-3">
                    <p><strong>@question.Text</strong></p>

                    @if (question.Type == QuestionType.OpenText)
                    {
                        var studentAnswer = submission.StudentAnswers
                        .FirstOrDefault(sa => sa.QuestionId == question.Id)
                        ?.OpenTextAnswer;

                        <p><em>Odpověď studenta:</em> @(string.IsNullOrWhiteSpace(studentAnswer) ? "<neodevzdal>" : studentAnswer)</p>

                        @if (isTeacher)
                        {
                            <p><em>Správná odpověď:</em> @question.CorrectAnswerText</p>
                        }
                    }

                    else
                    {
                        <ul>
                            @foreach (var option in question.Options)
                            {
                                var isSelected = submission.StudentAnswers.Any(sa => sa.AnswerOptionId == option.Id);
                                var isCorrect = option.IsCorrect;

                                <li style="color:@(isCorrect ? "green" : isSelected ? "red" : "black")">
                                    @(isSelected ? "✅ " : "❌ ") @option.Text
                                    @if (isCorrect && !isSelected)
                                    {
                                        <span class="text-success">(správná odpověď)</span>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </div>
            }
        }

    </div>
}

@code {
    [Parameter] public int SubmissionId { get; set; }

    private Submission? submission;
    private bool isLoading = true;
    private bool loadError = false;
    private bool isTeacher = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            submission = await SubmissionService.GetSubmissionWithDetailsAsync(SubmissionId);

            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            // Přepínání podle role
            isTeacher = user.IsInRole("Teacher");
        }
        catch
        {
            loadError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveFeedbackAsync()
    {
        if (submission != null && isTeacher)
        {
            await SubmissionService.UpdateSubmissionAsync(submission);
        }
    }

    private void BackToActivity()
    {
        if (submission != null)
        {
            Navigation.NavigateTo($"/activity-submissions/{submission.ActivityId}");
        }
        else
        {
            Navigation.NavigateTo("/my-grades");
        }
    }
}

@page "/admin/users"
@using Microsoft.EntityFrameworkCore
@using SchoolAssignments.Data
@using SchoolAssignments.Models
@inject AppDbContext Db
@inject NavigationManager Navigation

<h3>Správa uživatelů</h3>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Jméno</th>
            <th>Příjmení</th>
            <th>Email</th>
            <th>Role</th>
            <th>Akce</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in users)
        {
            <tr>
                <td>@user.FirstName</td>
                <td>@user.LastName</td>
                <td>@user.Email</td>
                <td>@user.Role</td>
                <td>
                    @if (user.Role == UserRole.Teacher)
                    {
                        <button class="btn btn-sm btn-primary" @onclick="() => EditTeacher(user.Id)">Upravit</button>
                    }
                    else if (user.Role == UserRole.Student)
                    {
                        <button class="btn btn-sm btn-primary" @onclick="() => EditStudent(user.Id)">Upravit</button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<User> users = new();

    protected override async Task OnInitializedAsync()
    {
        users = await Db.Users.ToListAsync();
    }

    private void EditTeacher(int id) => Navigation.NavigateTo($"/admin/edit-teacher/{id}");
    private void EditStudent(int id) => Navigation.NavigateTo($"/admin/edit-student/{id}");
}

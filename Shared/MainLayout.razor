@using System.Security.Claims
@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject CustomAuthenticationStateProvider CustomAuthProvider
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<PageTitle>SchoolAssignments</PageTitle>

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>
    <main>
        <div class="top-bar d-flex justify-content-between align-items-center px-4">
            <a href="/" class="brand">
                <i class="fas fa-graduation-cap me-2"></i>
                SchoolAssignments
            </a>

            <AuthorizeView>
                <Authorized Context="authContext">
                    @{
                        var user = authContext.User;
                        var username = user.Identity?.Name ?? "neznámý";
                        var role = user.FindFirst(ClaimTypes.Role)?.Value ?? "neznámá";
                        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                    }

                    <div class="user-dropdown">
                        <div class="dropdown">
                            <button class="btn dropdown-toggle d-flex align-items-center" type="button" id="userDropdown"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                <div class="user-avatar me-2">
                                    @if (!string.IsNullOrEmpty(user.FindFirst("ProfilePicturePath")?.Value))
                                    {
                                        <img src="@user.FindFirst("ProfilePicturePath")?.Value" alt="Avatar" class="rounded-circle" style="width:32px; height:32px; object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <i class="fas fa-user"></i>
                                    }
                                </div>

                                <div class="text-start">
                                    <strong>@username</strong>
                                    <small class="d-block">@role</small>
                                </div>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                <li>
                                    <NavLink class="dropdown-item" href=@($"/user-detail/{userId}")>
                                        <i class="fas fa-user me-2"></i>Můj profil
                                    </NavLink>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <button class="dropdown-item text-danger" @onclick="Logout">
                                        <i class="fas fa-sign-out-alt me-2"></i>Odhlásit
                                    </button>
                                </li>
                            </ul>
                        </div>
                    </div>
                </Authorized>

                <NotAuthorized>
                    <NavLink class="btn btn-outline-primary btn-sm" href="login">Přihlásit</NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private async Task Logout()
    {
        await CustomAuthProvider.LogoutAsync();
        Navigation.NavigateTo("/", forceLoad: true);
    }
}
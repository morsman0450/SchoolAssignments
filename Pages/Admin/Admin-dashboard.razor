@page "/admin-dashboard"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@using SchoolAssignments.Models
@using SchoolAssignments.Pages.Components
@using SchoolAssignments.Services
@attribute [Authorize(Roles = "Admin")]
@inject UserService UserService
@inject NavigationManager Navigation
@inject IActivityService ActivityService
@inject ISubmissionService SubmissionService
@inject IJSRuntime JS

<PageTitle>Dashboard | Administrace</PageTitle>

<div class="container py-4 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-shield-lock-fill text-primary me-2"></i>Admin Dashboard
            </h2>
            <p class="text-muted small mb-0">Vítejte v centrální správě systému. Zde je přehled aktuálního stavu.</p>
        </div>
        <div class="text-end">
            <span class="badge bg-dark rounded-pill px-3 py-2 shadow-sm">
                <i class="bi bi-cpu me-2"></i>Systém: OK
            </span>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 border-start border-4 border-primary rounded-4 transition-hover">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="stats-icon bg-primary-soft text-primary rounded-circle me-3">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small text-uppercase fw-bold mb-1">Uživatelé</h6>
                        <h3 class="fw-bold mb-0">@UserCount</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 border-start border-4 border-success rounded-4 transition-hover">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="stats-icon bg-success-soft text-success rounded-circle me-3">
                        <i class="bi bi-clipboard-check"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small text-uppercase fw-bold mb-1">Aktivní úkoly</h6>
                        <h3 class="fw-bold mb-0">@ActiveTasks</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 border-start border-4 border-warning rounded-4 transition-hover">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="stats-icon bg-warning-soft text-warning rounded-circle me-3">
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small text-uppercase fw-bold mb-1">Přihlášení (24h)</h6>
                        <h3 class="fw-bold mb-0">@ActiveUsers</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 border-start border-4 border-danger rounded-4 transition-hover">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="stats-icon bg-danger-soft text-danger rounded-circle me-3">
                        <i class="bi bi-bug"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small text-uppercase fw-bold mb-1">Chyby / Logy</h6>
                        <h3 class="fw-bold mb-0">@LogCount</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-graph-up text-primary me-2"></i>Aktivita za poslední týden</h5>
                </div>
                <div class="card-body p-4">
                    <div class="bg-light rounded-4 p-3 d-flex align-items-center justify-content-center" style="min-height: 250px;">
                        <canvas id="activityChart"></canvas>
                        @* Tady by byla inicializace Chart.js *@
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-list-stars text-primary me-2"></i>Poslední přihlášení</h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var user in LastLogins.Take(6))
                        {
                            <div class="list-group-item px-4 py-3 border-light border-0 border-bottom">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-circle-sm bg-light text-primary fw-bold me-3">
                                        @user.Username[0].ToString().ToUpper()
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="fw-bold text-dark small">@user.Username</div>
                                        <div class="text-muted extra-small">@user.LastLoginAt?.ToString("g")</div>
                                    </div>
                                    <div class="badge bg-success-soft text-success rounded-pill extra-small">Online</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="card-footer bg-white border-0 text-center py-3">
                    <a href="/admin/logs" class="text-primary text-decoration-none small fw-bold">Zobrazit všechny logy <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>

    <h5 class="fw-bold mb-3 mt-5 text-dark">Rychlá správa</h5>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 action-card h-100" @onclick='() => Navigation.NavigateTo("/admin/users")'>
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-primary-soft text-primary rounded-3 p-3 me-3">
                        <i class="bi bi-people fs-4"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1 text-dark">Správa uživatelů</h6>
                        <p class="text-muted small mb-0">Role, přístupy a profily.</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 action-card h-100" @onclick='() => Navigation.NavigateTo("/admin/assignments")'>
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-success-soft text-success rounded-3 p-3 me-3">
                        <i class="bi bi-list-check fs-4"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1 text-dark">Správa úkolů</h6>
                        <p class="text-muted small mb-0">Globální přehled aktivit.</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 action-card h-100" @onclick='() => Navigation.NavigateTo("/admin/settings")'>
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-secondary-soft text-secondary rounded-3 p-3 me-3">
                        <i class="bi bi-gear fs-4"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1 text-dark">Nastavení systému</h6>
                        <p class="text-muted small mb-0">Konfigurace a údržba.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* SOFT BARVY */
    .bg-primary-soft {
        background-color: rgba(13, 110, 253, 0.1);
    }

    .bg-success-soft {
        background-color: rgba(25, 135, 84, 0.1);
    }

    .bg-warning-soft {
        background-color: rgba(255, 193, 7, 0.15);
    }

    .bg-danger-soft {
        background-color: rgba(220, 53, 69, 0.1);
    }

    .bg-secondary-soft {
        background-color: rgba(108, 117, 125, 0.1);
    }

    .stats-icon {
        width: 52px;
        height: 52px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }

    .avatar-circle-sm {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
    }

    .extra-small {
        font-size: 0.7rem;
    }

    /* HOVER EFEKTY */
    .transition-hover {
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .transition-hover:hover {
            transform: translateY(-4px);
            box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.08) !important;
        }

    .action-card {
        cursor: pointer;
        transition: all 0.2s;
        border: 1px solid transparent !important;
    }

        .action-card:hover {
            background-color: #fcfcfc;
            border-color: rgba(13, 110, 253, 0.2) !important;
            transform: translateY(-2px);
        }
</style>

@code {
    private int UserCount, ActiveTasks, ActiveUsers, LogCount;
    private List<User> LastLogins = new();

    protected override async Task OnInitializedAsync()
    {
        UserCount = await UserService.GetUserCountAsync();
        ActiveTasks = await ActivityService.GetActiveActivitiesCountAsync();
        ActiveUsers = await UserService.GetActiveLast24hAsync();
        LogCount = await UserService.GetSystemLogCountAsync();
        LastLogins = await UserService.GetLastLoginsAsync();
    }
}

@page "/teacher-activities"
@using System.Security.Claims
@using SchoolAssignments.Models
@using SchoolAssignments.Services
@inject IActivityService ActivityService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<h3>Moje aktivity</h3>

@if (activities == null)
{
    <p><em>Načítám...</em></p>
}
else if (!activities.Any())
{
    <div class="oi-align-right mb-2">
        <button class="btn btn-sm btn-primary" @onclick="CreateActivity">Vytvořit aktivitu</button>
    </div>
    <p>Zatím jsi nevytvořil žádné aktivity.</p>
}
else
{
    <div class="oi-align-right mb-3 d-flex gap-2">
        <button class="btn btn-sm btn-primary" @onclick="CreateActivity">Vytvořit aktivitu</button>

        <select class="form-select w-auto" @bind="selectedSubject">
            <option value="">Všechny předměty</option>
            @foreach (var subj in subjects)
            {
                <option value="@subj">@subj</option>
            }
        </select>

        <select class="form-select w-auto" @bind="selectedDueFilter">
            <option value="">Všechny termíny</option>
            <option value="upcoming">Nadcházející</option>
            <option value="overdue">Po termínu</option>
            <option value="none">Bez termínu</option>
        </select>

        <select class="form-select w-auto" @bind="selectedReviewFilter">
            <option value="">Všechny</option>
            <option value="reviewed">Opravené</option>
            <option value="notreviewed">Neopravené</option>
        </select>
    </div>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Předmět</th>
                <th>Název</th>
                <th>Vytvořeno</th>
                <th>Termín odevzdání</th>
                <th>Akce</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in filteredActivities)
            {
                var localDue = a.DueDate?.ToLocalTime();
                <tr class="@GetDueDateRowClass(localDue)">
                    <td>@a.ClassTeacherSubject.Subject.Name</td>
                    <td>@a.Title</td>
                    <td>@a.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        @if (localDue.HasValue)
                        {
                            <span class="@GetDueDateBadgeClass(localDue.Value)">
                                @localDue.Value.ToString("dd.MM.yyyy HH:mm")
                                @if (GetDaysUntilDue(localDue.Value) >= 0)
                                {
                                    <small class="ms-1">(@GetDueDateText(localDue.Value))</small>
                                }
                                else
                                {
                                    <small class="ms-1 fw-bold">(po termínu)</small>
                                }
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">Bez termínu</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-primary" @onclick="@(() => EditActivity(a.Id))">Upravit</button>
                        <button class="btn btn-sm btn-danger" @onclick="@(() => DeleteActivity(a.Id))">Smazat</button>
                        <button class="btn btn-sm btn-secondary" @onclick="@(() => ReviewActivity(a.Id))">Odevzdáno</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Activity>? activities;
    private List<string> subjects = new();

    private string? selectedSubject;
    private string? selectedDueFilter;
    private string? selectedReviewFilter;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        var user = state.User;
        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (int.TryParse(userId, out var teacherId))
        {
            activities = await ActivityService.GetTeacherActivitiesAsync(teacherId);

            // naplnění seznamu předmětů
            subjects = activities
                .Select(a => a.ClassTeacherSubject.Subject.Name)
                .Distinct()
                .OrderBy(s => s)
                .ToList();
        }
        else
        {
            activities = new List<Activity>();
        }
    }

    // Filtrování
    private IEnumerable<Activity> filteredActivities => activities
        .Where(a =>
            (string.IsNullOrEmpty(selectedSubject) || a.ClassTeacherSubject.Subject.Name == selectedSubject) &&
            (string.IsNullOrEmpty(selectedDueFilter) ||
                (selectedDueFilter == "upcoming" && a.DueDate != null && a.DueDate > DateTime.UtcNow) ||
                (selectedDueFilter == "overdue" && a.DueDate != null && a.DueDate < DateTime.UtcNow) ||
                (selectedDueFilter == "none" && a.DueDate == null)
            ) &&
            (string.IsNullOrEmpty(selectedReviewFilter) ||
                (selectedReviewFilter == "reviewed" && a.Submissions.Any(s => s.Status == SubmissionStatus.Graded)) ||
(selectedReviewFilter == "notreviewed" && a.Submissions.Any(s => s.Status != SubmissionStatus.Graded))

            )
        );

    private void EditActivity(int id) => Navigation.NavigateTo($"/edit-activity/{id}");
    private void CreateActivity() => Navigation.NavigateTo($"/create-activity");
    private void ReviewActivity(int id) => Navigation.NavigateTo($"/activity-submissions/{id}");

    private async void DeleteActivity(int id)
    {
        await ActivityService.DeleteActivityAsync(id);

        var state = await AuthProvider.GetAuthenticationStateAsync();
        var user = state.User;
        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (int.TryParse(userId, out var teacherId))
        {
            activities = await ActivityService.GetTeacherActivitiesAsync(teacherId);
            subjects = activities
                .Select(a => a.ClassTeacherSubject.Subject.Name)
                .Distinct()
                .OrderBy(s => s)
                .ToList();
        }
        StateHasChanged();
    }

    // Metody pro určení vzhledu podle due date
    private string GetDueDateRowClass(DateTime? dueDate)
    {
        if (!dueDate.HasValue) return "";
        var daysUntil = GetDaysUntilDue(dueDate.Value);
        if (daysUntil < 0) return "due-overdue";
        if (daysUntil <= 1) return "due-urgent";
        if (daysUntil <= 3) return "due-soon";
        return "";
    }

    private string GetDueDateBadgeClass(DateTime dueDate)
    {
        var daysUntil = GetDaysUntilDue(dueDate);
        if (daysUntil < 0) return "badge-due-overdue";
        if (daysUntil <= 1) return "badge-due-urgent";
        if (daysUntil <= 3) return "badge-due-soon";
        return "badge-due-normal";
    }

    private int GetDaysUntilDue(DateTime dueDate)
    {
        var localDue = dueDate.ToLocalTime();
        return (int)(localDue.Date - DateTime.Now.Date).TotalDays;
    }

    private string GetDueDateText(DateTime dueDate)
    {
        var daysUntil = GetDaysUntilDue(dueDate);
        if (daysUntil == 0) return "dnes";
        if (daysUntil == 1) return "zítra";
        if (daysUntil > 1) return $"za {daysUntil} dnů";
        return $"před {Math.Abs(daysUntil)} dny";
    }
}

@page "/admin/classes"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@using SchoolAssignments.Models
@using SchoolAssignments.Services
@inject IClassService ClassService
@inject IJSRuntime JS

<div class="container mt-4 pb-5">
    <div class="mb-4">
        <h3 class="fw-bold text-dark mb-1">
            <i class="bi bi-collection text-primary me-2"></i>Správa tříd
        </h3>
        <p class="text-muted small">Vytvářejte nové třídy a spravujte jejich existující seznam.</p>
    </div>

    <div class="card border-0 shadow-sm mb-5 rounded-4">
        <div class="card-body p-4">
            <h6 class="text-primary fw-bold text-uppercase small mb-3 ls-1">Rychlé vytvoření</h6>
            <div class="row g-3 align-items-center">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted">
                            <i class="bi bi-pencil-square"></i>
                        </span>
                        <InputText @bind-Value="newClassName"
                                   class="form-control bg-light border-start-0 shadow-none py-2"
                                   placeholder="Např. 4.A nebo Programování 2024" />
                    </div>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-success w-100 py-2 rounded-3 shadow-sm fw-bold d-flex align-items-center justify-content-center gap-2"
                            @onclick="CreateClass"
                            disabled="@isCreating">
                        @if (isCreating)
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                        }
                        else
                        {
                            <i class="bi bi-plus-circle-fill"></i>
                        }
                        <span>Vytvořit třídu</span>
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(message))
            {
                <div class="alert @alertClass mt-3 mb-0 border-0 shadow-sm d-flex align-items-center animate-fade-in" role="alert">
                    <i class="bi @(alertClass.Contains("success") ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2"></i>
                    <div>@message</div>
                </div>
            }
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
            <p class="mt-3 text-muted fw-medium">Načítám seznam tříd...</p>
        </div>
    }
    else if (classes is null || !classes.Any())
    {
        <div class="card border-0 shadow-sm text-center py-5 rounded-4">
            <div class="card-body">
                <i class="bi bi-folder-x display-4 text-muted opacity-25"></i>
                <h5 class="mt-3 text-secondary">Zatím nejsou vytvořeny žádné třídy</h5>
                <p class="small text-muted">Použijte formulář nahoře pro založení první třídy.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm overflow-hidden rounded-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light border-bottom">
                        <tr class="text-secondary small text-uppercase fw-bold">
                            <th class="ps-4 py-3" style="width: 100px;">ID</th>
                            <th>Název třídy</th>
                            <th class="text-end pe-4">Akce</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in classes)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="badge bg-light text-muted border px-2">#@c.Id</span>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark fs-6">@c.Name</div>
                                </td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-sm btn-outline-danger border-0 rounded-3 px-3 py-2 transition-all hover-danger"
                                            @onclick="() => ConfirmDelete(c)">
                                        <i class="bi bi-trash3 me-1"></i> Smazat
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer bg-white py-3 border-top-0">
                <small class="text-muted">Celkem nalezeno: <strong>@classes.Count</strong> tříd.</small>
            </div>
        </div>
    }
</div>

<style>
    .ls-1 {
        letter-spacing: 0.5px;
    }

    /* Soft design pro input */
    .input-group-text {
        border-color: transparent;
    }

    .form-control:focus {
        background-color: #fff !important;
        border-color: #86b7fe;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.05) !important;
    }

    /* Efekt pro mazací tlačítko */
    .hover-danger:hover {
        background-color: rgba(220, 53, 69, 0.1);
        color: #dc3545;
    }

    .animate-fade-in {
        animation: fadeIn 0.3s ease-in;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .transition-all {
        transition: all 0.2s ease-in-out;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.02);
    }
</style>

@code {
    private List<Class> classes = new();
    private string newClassName = string.Empty;
    private string message = string.Empty;
    private string alertClass = string.Empty;
    private bool isLoading = true;
    private bool isCreating = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadClassesAsync();
    }

    private async Task LoadClassesAsync()
    {
        isLoading = true;
        try
        {
            classes = await ClassService.GetAllClassesAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateClass()
    {
        message = string.Empty;

        if (string.IsNullOrWhiteSpace(newClassName))
        {
            message = "Zadejte název třídy.";
            alertClass = "alert-warning";
            return;
        }

        isCreating = true;
        try
        {
            var c = await ClassService.CreateClassAsync(new Class
            {
                Name = newClassName.Trim(),
                IsActive = true
            });

            if (c != null)
            {
                classes.Add(c);
                message = $"✅ Třída '{newClassName}' byla vytvořena.";
                alertClass = "alert-success";
                newClassName = string.Empty;
            }
            else
            {
                message = "Nepodařilo se vytvořit třídu.";
                alertClass = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            message = "Došlo k chybě při vytváření třídy.";
            alertClass = "alert-danger";
            await JS.InvokeVoidAsync("console.error", ex.Message);
        }
        finally
        {
            isCreating = false;
        }
    }

    private async Task ConfirmDelete(Class c)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm",
            $"Opravdu chcete smazat třídu '{c.Name}'?");
        if (confirm)
        {
            await DeleteClass(c.Id);
        }
    }

    private async Task DeleteClass(int id)
    {
        try
        {
            await ClassService.DeleteClassAsync(id);
            classes = classes.Where(c => c.Id != id).ToList();

            message = "Třída byla úspěšně smazána.";
            alertClass = "alert-success";
        }
        catch (Exception ex)
        {
            message = "Chyba při mazání třídy.";
            alertClass = "alert-danger";
            await JS.InvokeVoidAsync("console.error", ex.Message);
        }
    }
}

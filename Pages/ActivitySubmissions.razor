@page "/activity-submissions/{ActivityId:int}"
@using SchoolAssignments.Models
@using SchoolAssignments.Services
@inject ISubmissionService SubmissionService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<h3>Odevzdání pro aktivitu</h3>

@if (isLoading)
{
    <p><em>Načítám...</em></p>
}
else if (loadError)
{
    <p class="text-danger">Nepodařilo se načíst odevzdání.</p>
}
else if (submissions.Any())
{
    <h5>@submissions.First().Activity.Title</h5>
    <p>@submissions.First().Activity.Description</p>

    <table class="table table-striped">
        <thead>
            <tr>
                @if (isTeacher)
                {
                    <th>Student</th>
                }
                <th>Odevzdáno</th>
                <th>Body</th>
                <th>Feedback</th>
                <th>Akce</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var submission in submissions.OrderByDescending(s => s.SubmittedAt))
            {
                <tr>
                    @if (isTeacher)
                    {
                        <td>@submission.Student.FirstName @submission.Student.LastName</td>
                    }
                    <td>@submission.SubmittedAt.ToLocalTime()</td>
                    <td>@(submission.Points?.ToString() ?? "-") / @submission.Activity.MaxPoints</td>
                    <td>@(string.IsNullOrEmpty(submission.Feedback) ? "-" : submission.Feedback)</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => ViewSubmission(submission.Id)">
                            Zobrazit
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>Žádná odevzdání pro tuto aktivitu.</p>
}

@code {
    [Parameter] public int ActivityId { get; set; }

    private List<Submission> submissions = new();
    private bool isLoading = true;
    private bool loadError = false;
    private bool isTeacher = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            isTeacher = user.IsInRole("Teacher");

            if (isTeacher)
            {
                submissions = await SubmissionService.GetSubmissionsByActivityAsync(ActivityId);
            }
            else
            {
                var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (int.TryParse(userId, out var studentId))
                {
                    submissions = await SubmissionService.GetStudentSubmissionsByActivityAsync(studentId, ActivityId);
                }
            }
        }
        catch
        {
            loadError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ViewSubmission(int submissionId)
    {
        Navigation.NavigateTo($"/submission-detail/{submissionId}");
    }
}

@using Microsoft.AspNetCore.Components

<div class="col-md-4 mb-3">
    <div class="card text-bg-@Color h-100">
        <div class="card-body d-flex flex-column justify-content-between">
            <div class="d-flex align-items-center">
                <i class="fas @Icon fa-2x me-3"></i>
                <h5 class="card-title mb-0">@Title</h5>
            </div>
            <div class="mt-3">
                <a href="@Url" class="btn btn-light w-100">Přejít</a>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Url { get; set; } = "#";
    [Parameter] public string Icon { get; set; } = "fa-circle";
    [Parameter] public string Color { get; set; } = "primary"; // primary, success, secondary...
}

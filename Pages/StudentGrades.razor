@page "/my-grades"
@using SchoolAssignments.Models
@using SchoolAssignments.Services
@inject ISubmissionService SubmissionService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<h3>Moje hodnocení</h3>

@if (summaries == null)
{
    <p><em>Načítám...</em></p>
}
else if (!summaries.Any())
{
    <p>Ještě jsi neodevzdával žádné aktivity.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Aktivita</th>
                <th>Poslední odevzdání</th>
                <th>Body</th>
                <th>Max. body</th>
                <th>Pokusy</th>
                <th>Akce</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in summaries)
            {
                <tr class="@GetStatusClass(s)">
                    <td>@s.Title</td>
                    <td>@s.LatestSubmissionDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@(s.LatestPoints.HasValue? s.LatestPoints.Value.ToString() : "-")</td>
                    <td>@s.MaxPoints</td>
                    <td>@s.AttemptsCount</td>
                    <td>
                        <button class="btn btn-sm btn-primary" @onclick="() => ViewSubmissionDetail(s.ActivityId)">Detail</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<StudentActivitySummary>? summaries;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (int.TryParse(userId, out var studentId))
        {
            summaries = await SubmissionService.GetStudentActivitySummariesAsync(studentId);
        }
        else
        {
            summaries = new List<StudentActivitySummary>();
        }
    }

    private void ViewSubmissionDetail(int activityId)
    {
        Navigation.NavigateTo($"/activity-submissions/{activityId}");
    }

    private string GetStatusClass(StudentActivitySummary s)
    {
        if (!s.LatestPoints.HasValue) return "table-warning";
        return s.LatestPoints >= s.MaxPoints ? "table-success" : "table-light";
    }
}

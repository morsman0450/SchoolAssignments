@page "/user-detail/{Id:int}"
@using SchoolAssignments.Models
@using SchoolAssignments.Services
@inject UserService UserService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

@attribute [Authorize]

<div class="container mt-4 pb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-2">
            <li class="breadcrumb-item"><a href="/admin/users" class="text-decoration-none">Správa uživatelů</a></li>
            <li class="breadcrumb-item active">Detail profilu</li>
        </ol>
    </nav>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
            <p class="mt-3 text-muted">Načítám profil uživatele...</p>
        </div>
    }
    else if (user == null)
    {
        <div class="alert alert-danger border-0 shadow-sm d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-octagon-fill fs-4 me-3"></i>
            <div>
                <h5 class="alert-heading mb-1 fw-bold">Uživatel nenalezen</h5>
                <p class="mb-0">Uživatel s ID @Id v databázi neexistuje.</p>
                <button class="btn btn-outline-danger btn-sm mt-3" @onclick="GoBack">Zpět na seznam</button>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden text-center h-100">
                    <div class="bg-primary shadow-sm" style="height: 100px;"></div>
                    <div class="card-body pt-0" style="margin-top: -50px;">
                        <div class="position-relative d-inline-block mb-3">
                            <img src="@GetProfilePicture()" alt="Profilová fotka"
                                 class="rounded-circle border border-4 border-white shadow"
                                 style="width: 120px; height: 120px; object-fit: cover;" />

                            <label class="position-absolute bottom-0 end-0 bg-white rounded-circle shadow-sm p-2 border cursor-pointer"
                                   style="width: 40px; height: 40px;" title="Změnit fotku">
                                <i class="bi bi-camera-fill text-primary"></i>
                                <InputFile OnChange="UploadProfilePicture" accept="image/*" class="d-none" />
                            </label>
                        </div>

                        <h4 class="fw-bold text-dark mb-1">@user.FirstName @user.LastName</h4>
                        <p class="text-muted small mb-3">@@@user.Username</p>

                        <span class="badge bg-primary-soft text-primary rounded-pill px-3 py-2 fw-bold mb-4">
                            @user.Role.ToString()
                        </span>

                        @if (isUploading)
                        {
                            <div class="progress mb-3" style="height: 5px;">
                                <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: 100%"></div>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(uploadMessage))
                        {
                            <div class="alert @(uploadSuccess ? "alert-success" : "alert-danger") py-2 small border-0 shadow-sm">
                                @uploadMessage
                            </div>
                        }

                        <hr class="my-4 opacity-10" />

                        <div class="d-grid gap-2">
                            <button class="btn btn-primary rounded-3 shadow-sm py-2 fw-bold" @onclick="ShowEditModal">
                                <i class="bi bi-pencil-square me-2"></i> Upravit profil
                            </button>
                            <button class="btn btn-outline-warning rounded-3 py-2 fw-bold" @onclick="ShowPasswordModal">
                                <i class="bi bi-key-fill me-2"></i> Změnit heslo
                            </button>
                            <AuthorizeView Roles="Admin">
                                <button class="btn btn-light text-danger rounded-3 py-2 fw-bold mt-2" @onclick="ShowDeleteModal">
                                    <i class="bi bi-trash3-fill me-2"></i> Smazat uživatele
                                </button>
                            </AuthorizeView>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-header bg-white py-3 border-0">
                        <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-person-lines-fill text-primary me-2"></i>Osobní informace</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="text-muted extra-small text-uppercase fw-bold ls-1 mb-1 d-block">ID Uživatele</label>
                                <div class="fw-bold text-dark p-2 bg-light rounded-3">#@user.Id</div>
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted extra-small text-uppercase fw-bold ls-1 mb-1 d-block">Emailová adresa</label>
                                <div class="fw-bold text-dark p-2 bg-light rounded-3">@user.Email</div>
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted extra-small text-uppercase fw-bold ls-1 mb-1 d-block">Celé jméno</label>
                                <div class="fw-bold text-dark p-2 bg-light rounded-3">@user.FirstName @user.LastName</div>
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted extra-small text-uppercase fw-bold ls-1 mb-1 d-block">Uživatelské jméno</label>
                                <div class="fw-bold text-dark p-2 bg-light rounded-3">@@@user.Username</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white py-3 border-0 text-start">
                        <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-activity text-primary me-2"></i>Aktivita v systému</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center">
                            <div class="bg-info-soft text-info rounded-circle p-3 me-3">
                                <i class="bi bi-clock-history fs-4"></i>
                            </div>
                            <div>
                                <label class="text-muted small d-block">Poslední přihlášení</label>
                                <span class="fw-bold fs-5">
                                    @(user.LastLoginAt.HasValue? user.LastLoginAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") : "Zatím neproběhlo")
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (showEditModal)
{
    <div class="modal fade show d-block animate-fade-in" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="fw-bold">Upravit údaje</h5>
                    <button type="button" class="btn-close" @onclick="CloseEditModal"></button>
                </div>
                <div class="modal-body p-4">
                    @if (saveMessage != null)
                    {
                        <div class="alert @(saveSuccess ? "alert-success" : "alert-danger") border-0 shadow-sm mb-3 py-2 small">@saveMessage</div>
                    }
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Uživatelské jméno</label>
                        <input type="text" class="form-control bg-light border-0 shadow-none py-2" @bind="editModel.Username" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Email</label>
                        <input type="email" class="form-control bg-light border-0 shadow-none py-2" @bind="editModel.Email" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold">Jméno</label>
                            <input type="text" class="form-control bg-light border-0 shadow-none py-2" @bind="editModel.FirstName" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold">Příjmení</label>
                            <input type="text" class="form-control bg-light border-0 shadow-none py-2" @bind="editModel.LastName" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button class="btn btn-light rounded-3 px-4 fw-bold" @onclick="CloseEditModal">Zrušit</button>
                    <button class="btn btn-primary rounded-3 px-4 fw-bold shadow-sm" @onclick="SaveEdit" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Uložit změny
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (showPasswordModal)
{
    <div class="modal fade show d-block animate-fade-in" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="fw-bold">Změna hesla</h5>
                    <button type="button" class="btn-close" @onclick="ClosePasswordModal"></button>
                </div>
                <div class="modal-body p-4">
                    @if (passwordMessage != null)
                    {
                        <div class="alert @(passwordSuccess ? "alert-success" : "alert-danger") border-0 shadow-sm mb-3 py-2 small">@passwordMessage</div>
                    }
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Současné heslo</label>
                        <input type="password" class="form-control bg-light border-0 shadow-none py-2" @bind="currentPassword" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Nové heslo</label>
                        <input type="password" class="form-control bg-light border-0 shadow-none py-2" @bind="newPassword" />
                    </div>
                    <div class="mb-1">
                        <label class="form-label small fw-bold text-muted">Potvrdit heslo</label>
                        <input type="password" class="form-control bg-light border-0 shadow-none py-2" @bind="confirmPassword" />
                    </div>
                    @if (!string.IsNullOrEmpty(passwordValidationMessage))
                    {
                        <small class="text-danger">@passwordValidationMessage</small>
                    }
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button class="btn btn-light rounded-3 px-4 fw-bold" @onclick="ClosePasswordModal">Zrušit</button>
                    <button class="btn btn-warning rounded-3 px-4 fw-bold shadow-sm" @onclick="ChangePassword" disabled="@isChangingPassword">
                        @if (isChangingPassword)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Změnit heslo
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (showDeleteModal)
{
    <div class="modal fade show d-block animate-fade-in" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-body p-4 text-center">
                    <div class="text-danger mb-3">
                        <i class="bi bi-exclamation-circle-fill display-4"></i>
                    </div>
                    <h5 class="fw-bold">Opravdu smazat?</h5>
                    <p class="text-muted small">Tato akce u uživatele <strong>@@@user?.Username</strong> je nevratná.</p>

                    <div class="d-flex gap-2 mt-4">
                        <button type="button" class="btn btn-light rounded-3 w-100 fw-bold" @onclick="CloseDeleteModal">Zrušit</button>
                        <button type="button" class="btn btn-danger rounded-3 w-100 fw-bold" @onclick="ConfirmDelete">Smazat</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

<style>
    .bg-primary-soft {
        background-color: rgba(13, 110, 253, 0.1);
    }

    .bg-info-soft {
        background-color: rgba(13, 202, 240, 0.1);
    }

    .ls-1 {
        letter-spacing: 0.5px;
    }

    .extra-small {
        font-size: 0.75rem;
    }

    .cursor-pointer {
        cursor: pointer;
    }

    .animate-fade-in {
        animation: fadeIn 0.3s ease-in;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
@code {
    [Parameter]
    public int Id { get; set; }

    private User? user;
    private bool isLoading = true;
    private int activeAssignments = 0;
    private int completedAssignments = 0;
    private int totalAssignments = 0;
    private User editModel = new();
    private bool isSaving = false;
    private string? saveMessage;
    private bool saveSuccess = false;
    private bool showEditModal = false;
    private bool showDeleteModal = false;

    // Proměnné pro změnu hesla
    private bool showPasswordModal = false;
    private string newPassword = "";
    private string confirmPassword = "";
    private bool isChangingPassword = false;
    private string? passwordMessage;
    private bool passwordSuccess = false;
    private string? passwordValidationMessage;
    private string currentPassword = ""; // Pro případné ověření aktuálního hesla, pokud je potřeba

    private bool isUploading = false;
    private string? uploadMessage;
    private bool uploadSuccess = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var currentUser = authState.User;

        if (currentUser.Identity is not { IsAuthenticated: true })
        {
            Navigation.NavigateTo("/login");
            return;
        }

        var currentUserId = int.Parse(currentUser.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "0");
        var currentUserRole = currentUser.FindFirst(ClaimTypes.Role)?.Value ?? "";

        // ✅ Pokud není admin a není to jeho vlastní profil → přesměrování
        if (currentUserId != Id && currentUserRole != "Admin")
        {
            Navigation.NavigateTo("/access-denied");
            return;
        }

        // ✅ Jinak můžeš načíst uživatele
        user = await UserService.GetUserByIdAsync(Id);
        await LoadUserData();
    }
    private async Task UploadProfilePicture(InputFileChangeEventArgs e)
    {
        try
        {
            if (user == null) return;

            var file = e.File;
            if (file == null)
            {
                uploadMessage = "Soubor nebyl vybrán.";
                uploadSuccess = false;
                return;
            }

            isUploading = true;
            uploadMessage = null;

            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024); // max 5 MB
            var updatedUser = await UserService.UpdateProfilePictureAsync(user.Id, stream, file.Name);

            if (updatedUser != null)
            {
                user = updatedUser;
                uploadMessage = "Profilová fotka byla úspěšně nahrána.";
                uploadSuccess = true;
            }
            else
            {
                uploadMessage = "Nepodařilo se uložit fotku.";
                uploadSuccess = false;
            }
        }
        catch (Exception ex)
        {
            uploadMessage = $"Chyba při nahrávání: {ex.Message}";
            uploadSuccess = false;
        }
        finally
        {
            isUploading = false;
        }
    }

    private string GetProfilePicture()
    {
        return string.IsNullOrEmpty(user?.ProfilePicturePath)
            ? "/images/default-avatar.png"
            : user.ProfilePicturePath!;
    }
    private void ShowEditModal()
    {
        PrepareEdit();
        saveMessage = null;
        showEditModal = true;
    }

    private void CloseEditModal()
    {
        showEditModal = false;
        saveMessage = null;
    }

    private void ShowPasswordModal()
    {
        currentPassword = "";
        newPassword = "";
        confirmPassword = "";
        passwordMessage = null;
        passwordValidationMessage = null;
        showPasswordModal = true;
    }

    private void ClosePasswordModal()
    {
        showPasswordModal = false;
        currentPassword = "";
        newPassword = "";
        confirmPassword = "";
        passwordMessage = null;
        passwordValidationMessage = null;
    }


    private void ShowDeleteModal()
    {
        showDeleteModal = true;
    }

    private void CloseDeleteModal()
    {
        showDeleteModal = false;
    }

    private void PrepareEdit()
    {
        if (user != null)
        {
            editModel = new User
            {
                Id = user.Id,
                Username = user.Username,
                Email = user.Email,
                FirstName = user.FirstName,
                LastName = user.LastName,
                Role = user.Role
            };
        }
    }

    private async Task SaveEdit()
    {
        try
        {
            isSaving = true;
            saveMessage = null;
            StateHasChanged();

            // Aktualizace uživatele v databázi
            var updatedUser = await UserService.UpdateUserAsync(editModel);

            if (updatedUser != null)
            {
                // Aktualizace lokálních dat
                user = updatedUser;
                saveMessage = "Uživatel byl úspěšně aktualizován.";
                saveSuccess = true;

                // Zavřít modal po úspěšném uložení
                await Task.Delay(1500); // Krátká pauza pro zobrazení zprávy
                CloseEditModal();
            }
            else
            {
                saveMessage = "Chyba při ukládání uživatele.";
                saveSuccess = false;
            }
        }
        catch (Exception ex)
        {
            saveMessage = $"Chyba při ukládání: {ex.Message}";
            saveSuccess = false;
            Console.WriteLine($"Chyba při ukládání: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task ChangePassword()
    {
        try
        {
            // Validace vstupů
            if (user == null)
            {
                passwordMessage = "Uživatel není načten.";
                passwordSuccess = false;
                return;
            }

            if (string.IsNullOrWhiteSpace(currentPassword) ||
                string.IsNullOrWhiteSpace(newPassword) ||
                string.IsNullOrWhiteSpace(confirmPassword))
            {
                passwordValidationMessage = "Všechna pole musí být vyplněna.";
                return;
            }

            if (newPassword != confirmPassword)
            {
                passwordValidationMessage = "Nové heslo a potvrzení se neshodují.";
                return;
            }

            if (newPassword.Length < 6)
            {
                passwordValidationMessage = "Heslo musí mít alespoň 6 znaků.";
                return;
            }

            passwordValidationMessage = null;
            isChangingPassword = true;
            passwordMessage = null;
            StateHasChanged();

            // Volání služby pro změnu hesla (včetně ověření aktuálního hesla)
            var updatedUser = await UserService.ChangePassword(user, newPassword, currentPassword);

            if (updatedUser != null)
            {
                passwordMessage = "Heslo bylo úspěšně změněno.";
                passwordSuccess = true;

                await Task.Delay(1500);
                ClosePasswordModal();
            }
            else
            {
                passwordMessage = "Stávající heslo je nesprávné nebo nastala jiná chyba.";
                passwordSuccess = false;
            }
        }
        catch (Exception ex)
        {
            passwordMessage = $"Chyba při změně hesla: {ex.Message}";
            passwordSuccess = false;
            Console.WriteLine($"Chyba při změně hesla: {ex.Message}");
        }
        finally
        {
            isChangingPassword = false;
            StateHasChanged();
        }
    }

    private async Task LoadUserData()
    {
        try
        {
            isLoading = true;
            user = await UserService.GetUserByIdAsync(Id);

            if (user != null)
            {
                await LoadUserStatistics();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Chyba při načítání uživatele: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadUserStatistics()
    {
        // Dočasné testovací hodnoty
        activeAssignments = 5;
        completedAssignments = 12;
        totalAssignments = 17;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/users");
    }

    private async Task ConfirmDelete()
    {
        try
        {
            CloseDeleteModal();
            Navigation.NavigateTo("/users");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Chyba při mazání uživatele: {ex.Message}");
        }
    }

    private string GetRoleBadgeClass(string role)
    {
        return role.ToLower() switch
        {
            "admin" => "danger",
            "teacher" => "primary",
            "student" => "success",
            _ => "secondary"
        };
    }
}
@page "/student-dashboard"
@using SchoolAssignments.DTOs
@using SchoolAssignments.Models
@using SchoolAssignments.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

@attribute [Authorize(Roles = "Student")]
@inject AuthenticationStateProvider AuthStateProvider
@inject IActivityService ActivityService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Studentský Dashboard</PageTitle>

<div class="container py-4">
    <h2 class="mb-4">🎓 Studentský dashboard</h2>

    <!-- Přehledové karty -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm text-center p-3">
                <h4>@totalPoints / @maxPoints</h4>
                <p>Celkové body</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm text-center p-3">
                <h4>@completedActivities</h4>
                <p>Splněné aktivity</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm text-center p-3">
                <h4>@pendingActivities</h4>
                <p>Čeká na odevzdání</p>
            </div>
        </div>
    </div>

    <!-- Tabulka aktivit -->
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            Moje aktivity
        </div>
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Název</th>
                        <th>Předmět</th>
                        <th>Body</th>
                        <th>Termín</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (studentActivities is not null && studentActivities.Any())
                    {
                        @foreach (var a in studentActivities)
                        {
                            var sub = GetLatestSubmission(a);

                            <tr>
                                <td>@a.Title</td>
                                <td>@a.ClassTeacherSubject.Subject.Name</td>
                                <td>@(sub?.Points ?? 0) / @a.MaxPoints</td>
                                <td class="@(a.DueDate < DateTime.Now ? "text-danger" : "")">
                                    @a.DueDate?.ToString("dd.MM.yyyy HH:mm")
                                </td>
                                <td>
                                    @if (sub?.Status == SubmissionStatus.Graded)
                                    {
                                        <span class="badge bg-success">Hodnoceno</span>
                                    }
                                    else if (sub?.Status == SubmissionStatus.Submitted)
                                    {
                                        <span class="badge bg-warning">Čeká na hodnocení</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Neodevzdáno</span>
                                    }
                                </td>
                            </tr>
                        }

                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-3">
                                Žádné aktivity k zobrazení.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private ClaimsPrincipal? user;
    private int studentId;

    private int totalPoints;
    private int maxPoints;
    private int completedActivities;
    private int pendingActivities;

    private List<Activity> studentActivities = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        user = authState.User;

        if (user?.Identity?.IsAuthenticated != true) return;

        studentId = int.Parse(user.FindFirst(ClaimTypes.NameIdentifier)!.Value);

        // Použiješ původní metodu, která vrací List<Activity>
        studentActivities = await ActivityService.GetStudentActivitiesAsync(studentId);

        // Spočítej přehledové karty
        totalPoints = studentActivities
            .SelectMany(a => a.Submissions.Where(s => s.StudentId == studentId))
            .Sum(s => s.Points ?? 0);

        maxPoints = studentActivities.Sum(a => a.MaxPoints);

        completedActivities = studentActivities
            .Count(a => a.Submissions.Any(s => s.StudentId == studentId && s.Status == SubmissionStatus.Graded));

        pendingActivities = studentActivities
            .Count(a => a.Submissions.Any(s => s.StudentId == studentId && s.Status == SubmissionStatus.Submitted));
    }

    private Submission? GetLatestSubmission(Activity activity)
    {
        return activity.Submissions
            .Where(s => s.StudentId == studentId)
            .OrderByDescending(s => s.SubmittedAt)
            .FirstOrDefault();
    }
}


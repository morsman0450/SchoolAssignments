@using SchoolAssignments.Models
@inject IJSRuntime JSRuntime

<div class="mb-3">
    <label for="language" class="form-label">Programovací jazyk</label>
    <InputSelect id="language" class="form-select" @bind-Value="Model.Language">
        <option value="csharp">C#</option>
        <option value="python">Python</option>
        <option value="javascript">JavaScript</option>
    </InputSelect>
</div>

<div class="mb-3">
    <label class="form-label">Výchozí kód</label>
    <div id="@editorId" style="height:400px;border:1px solid #ccc;"></div>
</div>

@code {
    [Parameter] public CodeActivityModel Model { get; set; } = default!;
    private string editorId = $"code-editor-{Guid.NewGuid()}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initMonaco", editorId, Model.InitialCode ?? "", Model.Language ?? "csharp");
        }
    }

    [JSInvokable]
    public void UpdateCode(string code)
    {
        Model.InitialCode = code;
    }
}

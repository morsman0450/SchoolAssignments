@page "/teacher-dashboard"
@using System.Security.Claims
@using SchoolAssignments.Models
@using SchoolAssignments.Services
@inject IClassService ClassService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Dashboard | Portál učitele</PageTitle>

<div class="container mt-4 pb-5">
    <div class="row align-items-center mb-4">
        <div class="col">
            <h2 class="fw-bold text-dark mb-1">Dobrý den, pane učiteli! 👋</h2>
            <p class="text-muted mb-0">Zde je rychlý přehled vaší aktuální výuky a úkolů.</p>
        </div>
        <div class="col-auto">
            <div class="d-flex gap-2">
                <NavLink class="btn btn-primary shadow-sm px-4 py-2 fw-bold" href="/create-activity">
                    <i class="bi bi-plus-lg me-2"></i>Nová aktivita
                </NavLink>
                <NavLink class="btn btn-white border shadow-sm px-4 py-2" href="/teacher-statistics">
                    <i class="bi bi-bar-chart-fill text-secondary me-2"></i>Statistiky
                </NavLink>
            </div>
        </div>
    </div>

    @if (classes == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 text-muted">Připravuji váš přehled...</p>
        </div>
    }
    else
    {
        <div class="row g-4 mb-5">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100 bg-white p-2">
                    <div class="card-body d-flex align-items-center">
                        <div class="stats-icon bg-primary-soft text-primary rounded-circle me-3">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <div>
                            <h6 class="text-muted small text-uppercase fw-bold mb-1">Třídy</h6>
                            <h3 class="fw-bold mb-0">@classes.Count</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100 bg-white p-2">
                    <div class="card-body d-flex align-items-center">
                        <div class="stats-icon bg-info-soft text-info rounded-circle me-3">
                            <i class="bi bi-person-badge-fill"></i>
                        </div>
                        <div>
                            <h6 class="text-muted small text-uppercase fw-bold mb-1">Studenti</h6>
                            <h3 class="fw-bold mb-0">@classes.Sum(c => c.Students.Count)</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100 bg-white p-2">
                    <div class="card-body d-flex align-items-center">
                        <div class="stats-icon bg-success-soft text-success rounded-circle me-3">
                            <i class="bi bi-journal-check"></i>
                        </div>
                        <div>
                            <h6 class="text-muted small text-uppercase fw-bold mb-1">Aktivity</h6>
                            <h3 class="fw-bold mb-0">@classes.Sum(c => c.Activities.Count)</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100 bg-white p-2 border-start border-warning border-4">
                    <div class="card-body d-flex align-items-center">
                        <div class="stats-icon bg-warning-soft text-warning rounded-circle me-3">
                            <i class="bi bi-clock-history"></i>
                        </div>
                        <div>
                            <h6 class="text-muted small text-uppercase fw-bold mb-1">K opravě</h6>
                            <h3 class="fw-bold mb-0 text-warning">
                                @classes.Sum(c => c.Activities.Count(a => !a.IsActive))
                            </h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm overflow-hidden">
            <div class="card-header bg-white py-3 border-bottom-0">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0"><i class="bi bi-book text-primary me-2"></i>Vaše aktuální třídy</h5>
                    <a href="/teacher-classes" class="btn btn-sm btn-link text-decoration-none p-0">Spravovat vše</a>
                </div>
            </div>
            <div class="table-responsive">
                @if (!classes.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-clipboard-x text-muted display-4"></i>
                        <p class="text-muted mt-2">Zatím nemáte přiřazené žádné třídy.</p>
                    </div>
                }
                else
                {
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr class="text-muted small text-uppercase">
                                <th class="ps-4">Název třídy</th>
                                <th>Hlavní předmět</th>
                                <th class="text-center">Studenti</th>
                                <th class="text-center">Aktivity</th>
                                <th class="pe-4 text-end">Akce</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in classes)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="fw-bold text-dark">@c.Name</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-primary border px-2 py-1 fw-medium">
                                            @c.Subject
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="text-muted">@c.Students.Count</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge rounded-pill bg-dark">@c.Activities.Count</span>
                                    </td>
                                    <td class="pe-4 text-end">
                                        <NavLink class="btn btn-sm btn-outline-primary rounded-pill px-3"
                                                 href="@($"/class-detail/{c.Id}")">
                                            Spravovat <i class="bi bi-chevron-right ms-1"></i>
                                        </NavLink>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
            <div class="card-footer bg-light py-3 border-top-0">
                <small class="text-muted">Poslední aktualizace dat: @DateTime.Now.ToString("HH:mm")</small>
            </div>
        </div>
    }
</div>

<style>
    /* "Soft" barvy pro ikony */
    .bg-primary-soft {
        background-color: rgba(13, 110, 253, 0.1);
    }

    .bg-success-soft {
        background-color: rgba(25, 135, 84, 0.1);
    }

    .bg-info-soft {
        background-color: rgba(13, 202, 240, 0.1);
    }

    .bg-warning-soft {
        background-color: rgba(255, 193, 7, 0.1);
    }

    .stats-icon {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
    }

    .btn-white {
        background-color: #fff;
    }

        .btn-white:hover {
            background-color: #f8f9fa;
        }

    .table-hover tbody tr:hover {
        background-color: rgba(0,0,0, .02);
    }
</style>

@code {
    private List<Class>? classes;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated ?? false)
        {
            var teacherId = int.Parse(user.FindFirst(ClaimTypes.NameIdentifier)!.Value);
            classes = await ClassService.GetTeacherClassesAsync(teacherId);
        }
    }
}

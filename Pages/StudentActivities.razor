@page "/student-activities"
@using System.Security.Claims
@using SchoolAssignments.Models
@using SchoolAssignments.Services
@inject IActivityService ActivityService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<h3>Moje aktivity</h3>

<!-- Přidané filtrovací UI -->
<div class="row mb-3">
    <div class="col-md-4">
        <label class="form-label">Vyhledat podle názvu:</label>
        <input type="text" class="form-control" @bind="searchTerm" @oninput="OnSearchChanged" placeholder="Zadejte název aktivity..." />
    </div>
    <div class="col-md-3">
        <label class="form-label">Filtr podle předmětu:</label>
        <select class="form-select" value="@selectedSubjectId" @onchange="OnSubjectFilterChanged">
            <option value="">Všechny předměty</option>
            @if (activities != null)
            {
                @foreach (var subject in activities.Where(a => a.ClassTeacherSubject?.Subject != null)
                            .GroupBy(a => a.ClassTeacherSubject.Subject.Id)
                            .Select(g => g.First().ClassTeacherSubject.Subject))
                {
                    <option value="@subject.Id">@subject.Name</option>
                }
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label">Filtr podle stavu:</label>
        <select class="form-select" value="@selectedStatus" @onchange="OnStatusFilterChanged">
            <option value="all">Všechny aktivity</option>
            <option value="active">Aktivní</option>
            <option value="overdue">Po termínu</option>
            <option value="completed">Dokončené</option>
        </select>
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button type="button" class="btn btn-secondary" @onclick="ClearFilters">Vymazat filtry</button>
    </div>
</div>

@if (filteredActivities == null)
{
    <p><em>Načítám...</em></p>
}
else if (!filteredActivities.Any())
{
    <p>Nemáte žádné aktivity podle zadaných filtrů.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Název</th>
                <th>Předmět</th>
                <th>Vytvořeno</th>
                <th>Termín odevzdání</th>
                <th>Pokusy</th>
                <th>Akce</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in filteredActivities)
            {
                var usedAttempts = a.UsedAttempts;
                var maxAttempts = a.MaxAttempts;
                var attemptsExceeded = maxAttempts > 0 && usedAttempts >= maxAttempts;
                var isOverdue = a.DueDate.HasValue && IsOverdue(a.DueDate.Value);

                <tr class="@GetDueDateRowClass(a.DueDate, attemptsExceeded)">
                    <td>@a.Title</td>
                    <td>@(a.ClassTeacherSubject?.Subject?.Name ?? "neuvedeno")</td>
                    <td>@a.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        @if (a.DueDate.HasValue)
                        {
                            var localDue = a.DueDate.Value.ToLocalTime();
                            <span class="@GetDueDateBadgeClass(localDue, attemptsExceeded)">
                                @localDue.ToString("dd.MM.yyyy HH:mm")
                                @if (!IsOverdue(localDue))
                                {
                                    <small class="ms-1">(@GetDueDateText(localDue))</small>
                                }
                                else
                                {
                                    <small class="ms-1 fw-bold">(po termínu)</small>
                                }
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">Bez termínu</span>
                        }
                </td>
                <td>
                    @(maxAttempts == 0
                                    ? usedAttempts.ToString()
                                    : $"{usedAttempts} / {maxAttempts}")
            </td>
            <td>
                <button class="btn btn-sm btn-primary"
                        @onclick="@(() => TakeActivity(a.Id))"
                        disabled="@(attemptsExceeded || isOverdue)">
                    Začít
                </button>
            </td>
        </tr>
                }
        </tbody>
    </table>
}

<style>
    .due-soon {
        background-color: #fff3cd !important;
    }

    .due-urgent {
        background-color: #f8d7da !important;
    }

    .due-overdue {
        background-color: #f5c6cb !important;
    }

    .badge-due-normal {
        background-color: #28a745;
        color: white;
        padding: 0.25em 0.5em;
        border-radius: 0.25rem;
        font-size: 0.875em;
    }

    .badge-due-soon {
        background-color: #ffc107;
        color: #212529;
        padding: 0.25em 0.5em;
        border-radius: 0.25rem;
        font-size: 0.875em;
    }

    .badge-due-urgent {
        background-color: #fd7e14;
        color: white;
        padding: 0.25em 0.5em;
        border-radius: 0.25rem;
        font-size: 0.875em;
    }

    .badge-due-overdue {
        background-color: #dc3545;
        color: white;
        padding: 0.25em 0.5em;
        border-radius: 0.25rem;
        font-size: 0.875em;
    }

    .attempts-exceeded {
        opacity: 0.6;
        background-color: #e9ecef !important;
    }
</style>

@code {
    private List<Activity>? activities;          // všechny aktivity studenta
    private List<Activity>? filteredActivities;  // filtrovaný výběr

    private int? selectedSubjectId;              // vybraný předmět pro filtr
    private string searchTerm = string.Empty;    // vyhledávání podle názvu
    private string selectedStatus = "all";       // filtr podle stavu

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        var user = state.User;
        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (int.TryParse(userId, out var studentId))
        {
            activities = await ActivityService.GetStudentActivitiesAsync(studentId);
            ApplyFilters(); // Aplikujeme filtry při inicializaci
        }
        else
        {
            activities = new List<Activity>();
            filteredActivities = new List<Activity>();
        }
    }

    private void ApplyFilters()
    {
        if (activities == null) return;

        filteredActivities = activities
            .Where(a =>
                (string.IsNullOrWhiteSpace(searchTerm) ||
                 a.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) &&
                (!selectedSubjectId.HasValue ||
                 a.ClassTeacherSubject?.SubjectId == selectedSubjectId.Value) &&
                (selectedStatus == "all" ||
                 (selectedStatus == "active" && !IsOverdue(a) && !IsCompleted(a)) ||
                 (selectedStatus == "overdue" && IsOverdue(a)) ||
                 (selectedStatus == "completed" && IsCompleted(a)))
            )
            .OrderByDescending(a => IsOverdue(a)) // Po termínu dolů
            .ThenBy(a => a.DueDate ?? DateTime.MaxValue) // Pak seřadit podle termínu
            .ToList();
    }

    private bool IsOverdue(Activity activity)
    {
        return activity.DueDate.HasValue && IsOverdue(activity.DueDate.Value);
    }

    private bool IsOverdue(DateTime dueDate)
    {
        var localDue = dueDate.ToLocalTime();
        return localDue < DateTime.Now;
    }

    private bool IsCompleted(Activity activity)
    {
        var maxAttempts = activity.MaxAttempts;
        var usedAttempts = activity.UsedAttempts;
        return maxAttempts > 0 && usedAttempts >= maxAttempts;
    }

    // Nové event handlery pro filtry
    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;
        ApplyFilters();
        StateHasChanged();
    }

    private async Task OnSubjectFilterChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var subjectId))
        {
            selectedSubjectId = subjectId;
        }
        else
        {
            selectedSubjectId = null;
        }
        ApplyFilters();
        StateHasChanged();
    }

    private async Task OnStatusFilterChanged(ChangeEventArgs e)
    {
        selectedStatus = e.Value?.ToString() ?? "all";
        ApplyFilters();
        StateHasChanged();
    }

    private void ClearFilters()
    {
        searchTerm = string.Empty;
        selectedSubjectId = null;
        selectedStatus = "all";
        ApplyFilters();
    }

    private void TakeActivity(int id)
    {
        Navigation.NavigateTo($"/take-activity/{id}");
    }

    private string GetDueDateRowClass(DateTime? dueDate, bool attemptsExceeded = false)
    {
        if (!dueDate.HasValue && !attemptsExceeded) return "";
        var classes = new List<string>();
        if (dueDate.HasValue)
        {
            var localDue = dueDate.Value.ToLocalTime();

            if (IsOverdue(localDue)) classes.Add("due-overdue");
            else if (GetHoursUntilDue(localDue) <= 24) classes.Add("due-urgent");
            else if (GetHoursUntilDue(localDue) <= 72) classes.Add("due-soon");
        }
        if (attemptsExceeded) classes.Add("attempts-exceeded");

        return string.Join(" ", classes);
    }

    private string GetDueDateBadgeClass(DateTime dueDate, bool attemptsExceeded = false)
    {
        if (attemptsExceeded) return "badge-due-overdue";
        if (IsOverdue(dueDate)) return "badge-due-overdue";
        if (GetHoursUntilDue(dueDate) <= 24) return "badge-due-urgent";
        if (GetHoursUntilDue(dueDate) <= 72) return "badge-due-soon";
        return "badge-due-normal";
    }

    private double GetHoursUntilDue(DateTime dueDate)
    {
        var localDue = dueDate.ToLocalTime();
        return (localDue - DateTime.Now).TotalHours;
    }

    private string GetDueDateText(DateTime dueDate)
    {
        var hoursUntil = GetHoursUntilDue(dueDate);

        if (hoursUntil < 0) return "po termínu";
        if (hoursUntil < 1) return $"za {(int)(hoursUntil * 60)} minut";
        if (hoursUntil < 24) return $"za {(int)hoursUntil} hodin";
        if (hoursUntil < 48) return "zítra";

        var days = (int)(hoursUntil / 24);
        return $"za {days} dnů";
    }
}
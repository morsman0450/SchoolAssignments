@page "/student-activities"
@using System.Security.Claims
@using SchoolAssignments.Models
@using SchoolAssignments.Services
@inject IActivityService ActivityService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<h3>Moje aktivity</h3>

@if (activities == null)
{
    <p><em>Načítám...</em></p>
}
else if (!activities.Any())
{
    <p>Nemáte žádné aktivity.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Název</th>
                <th>Vytvořeno</th>
                <th>Termín odevzdání</th>
                <th>Pokusy</th>
                <th>Akce</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in activities)
            {
                var usedAttempts = a.UsedAttempts; // počet odevzdaných pokusů
                var maxAttempts = a.MaxAttempts;   // max pokusů, 0 = neomezeně
                var attemptsExceeded = maxAttempts > 0 && usedAttempts >= maxAttempts;

                <tr class="@GetDueDateRowClass(a.DueDate, attemptsExceeded)">
                    <td>@a.Title</td>
                    <td>@a.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        @if (a.DueDate.HasValue)
                        {
                            var localDue = a.DueDate.Value.ToLocalTime();
                            <span class="@GetDueDateBadgeClass(localDue, attemptsExceeded)">
                                @localDue.ToString("dd.MM.yyyy HH:mm")
                                @if (GetDaysUntilDue(localDue) >= 0)
                                {
                                    <small class="ms-1">(@GetDueDateText(localDue))</small>
                                }
                                else
                                {
                                    <small class="ms-1 fw-bold">(po termínu)</small>
                                }
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">Bez termínu</span>
                        }
                    </td>
                    <td>
                        @if (maxAttempts == 0)
                        {
                            @usedAttempts
                        }
                        else
                        {
                            @(maxAttempts == 0 ? $"{usedAttempts}" : $"{usedAttempts} / {maxAttempts}")

                                }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-primary" @onclick="@(() => TakeActivity(a.Id))" disabled="@(attemptsExceeded || (a.DueDate.HasValue && GetDaysUntilDue(a.DueDate.Value) < 0))">
                            Začít
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<style>
    .due-soon {
        background-color: #fff3cd !important;
    }

    .due-urgent {
        background-color: #f8d7da !important;
    }

    .due-overdue {
        background-color: #f5c6cb !important;
    }

    .badge-due-normal {
        background-color: #28a745;
        color: white;
        padding: 0.25em 0.5em;
        border-radius: 0.25rem;
        font-size: 0.875em;
    }

    .badge-due-soon {
        background-color: #ffc107;
        color: #212529;
        padding: 0.25em 0.5em;
        border-radius: 0.25rem;
        font-size: 0.875em;
    }

    .badge-due-urgent {
        background-color: #fd7e14;
        color: white;
        padding: 0.25em 0.5em;
        border-radius: 0.25rem;
        font-size: 0.875em;
    }

    .badge-due-overdue {
        background-color: #dc3545;
        color: white;
        padding: 0.25em 0.5em;
        border-radius: 0.25rem;
        font-size: 0.875em;
    }

    .attempts-exceeded {
        opacity: 0.6;
        background-color: #e9ecef !important;
    }
</style>

@code {
    private List<Activity>? activities;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        var user = state.User;
        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (int.TryParse(userId, out var studentId))
        {
            activities = await ActivityService.GetStudentActivitiesAsync(studentId);
        }
        else
        {
            activities = new List<Activity>();
        }
    }

    private void TakeActivity(int id)
    {
        Navigation.NavigateTo($"/take-activity/{id}");
    }

    private int GetDaysUntilDue(DateTime dueDate)
    {
        var localDue = dueDate.ToLocalTime();
        return (int)(localDue.Date - DateTime.Now.Date).TotalDays;
    }

    private string GetDueDateRowClass(DateTime? dueDate, bool attemptsExceeded = false)
    {
        if (!dueDate.HasValue && !attemptsExceeded) return "";
        var classes = new List<string>();
        if (dueDate.HasValue)
        {
            var localDue = dueDate.Value.ToLocalTime();
            var daysUntil = GetDaysUntilDue(localDue);

            if (daysUntil < 0) classes.Add("due-overdue");
            else if (daysUntil <= 1) classes.Add("due-urgent");
            else if (daysUntil <= 3) classes.Add("due-soon");
        }
        if (attemptsExceeded) classes.Add("attempts-exceeded");

        return string.Join(" ", classes);
    }

    private string GetDueDateBadgeClass(DateTime dueDate, bool attemptsExceeded = false)
    {
        var daysUntil = GetDaysUntilDue(dueDate);

        if (attemptsExceeded) return "badge-due-overdue";
        if (daysUntil < 0) return "badge-due-overdue";
        if (daysUntil <= 1) return "badge-due-urgent";
        if (daysUntil <= 3) return "badge-due-soon";
        return "badge-due-normal";
    }

    private string GetDueDateText(DateTime dueDate)
    {
        var daysUntil = GetDaysUntilDue(dueDate);

        if (daysUntil == 0) return "dnes";
        if (daysUntil == 1) return "zítra";
        if (daysUntil > 1) return $"za {daysUntil} dnů";
        return $"před {Math.Abs(daysUntil)} dny";
    }
}
